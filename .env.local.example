# Supabase — copy to .env.local and fill in. Never commit real keys.

# Public (exposed to the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only — used for privileged writes from the scoring API.
# Do NOT prefix with NEXT_PUBLIC; this must never reach the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare Turnstile (CAPTCHA on public forms). Optional: forms work without
# these; setting BOTH activates the CAPTCHA. Create a free widget at
# https://dash.cloudflare.com → Turnstile. Add both to Netlify env vars too.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Stripe (Academy membership billing). Test keys (sk_test_/pk_test_) first, then
# live. Secret + webhook secret are server-only (no NEXT_PUBLIC). Also set these
# in Netlify env vars for production.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
